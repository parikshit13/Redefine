{
  "expo": {
    "name": "Redefine",
    "slug": "Redefine",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0B0D11"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.redefine.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0B0D11"
      },
      "package": "com.redefine.app",
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro",
      "output": "server"
    },
    "scheme": "redefine",
    "plugins": [
      "expo-font",
      "expo-router",
      "expo-web-browser",
      "@react-native-community/datetimepicker"
    ]
  }
}
